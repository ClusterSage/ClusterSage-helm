{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "frontend",
    "backend"
  ],
  "properties": {
    "frontend": {
      "type": "object",
      "required": [
        "image"
      ],
      "properties": {
        "image": {
          "type": "object",
          "required": [
            "repository"
          ],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "minReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "resources": {
          "type": "object"
        },
        "probes": {
          "type": "object"
        }
      }
    },
    "backend": {
      "type": "object",
      "required": [
        "image",
        "secrets"
      ],
      "properties": {
        "image": {
          "type": "object",
          "required": [
            "repository"
          ],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "resources": {
          "type": "object"
        },
        "probes": {
          "type": "object"
        },
        "secrets": {
          "type": "object",
          "required": [
            "DATABASE_URL",
            "JWT_SECRET",
            "AGENT_TOKEN_SECRET",
            "AZURE_STORAGE_CONNECTION_STRING"
          ],
          "properties": {
            "DATABASE_URL": {
              "type": "string"
            },
            "JWT_SECRET": {
              "type": "string"
            },
            "AGENT_TOKEN_SECRET": {
              "type": "string"
            },
            "AZURE_STORAGE_CONNECTION_STRING": {
              "type": "string"
            },
            "AZURE_SERVICEBUS_CONNECTION_STRING": {
              "type": "string"
            },
            "AZURE_COMMUNICATION_EMAIL_CONNECTION_STRING": {
              "type": "string"
            },
            "AZURE_OPENAI_API_KEY": {
              "type": "string"
            }
          }
        }
      }
    },
    "emailWorker": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 0
        },
        "resources": {
          "type": "object"
        },
        "image": {
          "type": "object",
          "required": [
            "repository"
          ],
          "properties": {
            "repository": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "migrationJob": {
      "type": "object",
      "properties": {
        "image": {
          "type": "object",
          "properties": {
            "repository": {
              "type": "string"
            },
            "tag": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
