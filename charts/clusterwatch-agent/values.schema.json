{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["backend", "auth", "cluster", "agent"],
  "properties": {
    "backend": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "minLength": 1 }
      }
    },
    "auth": {
      "type": "object",
      "required": ["email", "accessKey"],
      "properties": {
        "email": { "type": "string", "minLength": 1 },
        "accessKey": { "type": "string", "minLength": 1 }
      }
    },
    "cluster": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "provider": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "agent": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "logLevel": { "type": "string" },
        "heartbeatIntervalSeconds": { "type": "integer", "minimum": 1 },
        "snapshotIntervalSeconds": { "type": "integer", "minimum": 1 },
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "intervalSeconds": { "type": "integer", "minimum": 5 },
            "resourceUsage": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            },
            "kubeStateMetrics": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "url": { "type": "string" },
                "timeoutSeconds": { "type": "integer", "minimum": 1 }
              }
            },
            "kubeletSummary": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "remediation": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "clusterWide": { "type": "boolean" },
        "allowedNamespaces": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "allowedActions": {
          "type": "array",
          "items": { "type": "string", "enum": ["rollout_restart"] },
          "minItems": 1
        },
        "pollIntervalSeconds": { "type": "integer", "minimum": 5 },
        "requireServerApproval": { "type": "boolean" }
      }
    },
    "addons": {
      "type": "object",
      "properties": {
        "kubeStateMetrics": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "metricsServer": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "insecureKubeletTls": { "type": "boolean" },
            "metricResolution": { "type": "string", "minLength": 2 }
          }
        }
      }
    }
  }
}
